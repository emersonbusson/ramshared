[Desktop Entry]
Type=Application
Name=RamShared Cushion
Comment=Borrow idle GPU memory when RAM is tight — give it back when the GPU needs it
Exec=@SCRIPTS_PATH@/cascade-app.sh --gui menu
Icon=utilities-system-monitor
Terminal=false
Categories=System;Monitor;
Keywords=memory;swap;vram;gpu;wsl;
StartupNotify=true
